# Frontend public key for Turnstile widget
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Optional override for verification endpoint URL
VITE_TURNSTILE_VERIFY_URL=/api/turnstile-verify

# Server-side secret key (set this only in hosting environment variables)
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key
